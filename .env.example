APP_NAME="Rock Bluffs Exterior Services"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://exterior.rockbluffs.com
APP_TIMEZONE=America/Chicago
APP_KEY=change-this-to-a-long-random-value

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rockbluffs_exterior
DB_USERNAME=rockbluffs
DB_PASSWORD=change-me

SESSION_NAME=rbexterior_session
SESSION_SECURE=true

M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_REDIRECT_URI=https://exterior.rockbluffs.com/auth/microsoft/callback
M365_SHARED_MAILBOX=exteriorservices@rockbluffs.com
M365_CALENDAR_ID=
M365_SHAREPOINT_SITE_ID=
M365_SHAREPOINT_DRIVE_ID=
M365_GRAPH_WEBHOOK_SECRET=change-this-random-value
UPLOAD_MAX_MB=10

M365_SHAREPOINT_BASE_FOLDER=Exterior Services
TEAMS_WEBHOOK_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
PAYMENT_SUCCESS_URL=https://exterior.rockbluffs.com/payment/success
PAYMENT_CANCEL_URL=https://exterior.rockbluffs.com/payment/cancel
REMINDER_LOOKAHEAD_HOURS=24
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Phase 6 SMS integration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional dispatch behavior
TECHNICIAN_LOCATION_RETENTION_DAYS=30

# Phase 7
TWILIO_STATUS_CALLBACK_URL=https://example.com/webhooks/twilio/status
CALENDAR_TWO_WAY_SYNC=true
TECHNICIAN_DEFAULT_HOURLY_COST=22.00

# QuickBooks Online (Phase 9)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://exterior.rockbluffs.com/auth/quickbooks/callback

# Optional external route matrix provider
ROUTE_MATRIX_PROVIDER=local
ROUTE_MATRIX_API_KEY=

# Phase 10 routing, backups, and accounting
ROUTE_MATRIX_PROVIDER=local
ROUTE_MATRIX_API_KEY=
ROUTE_MATRIX_BASE_URL=
BACKUP_DIRECTORY=/var/backups/rockbluffs-exterior
BACKUP_RETENTION_DAYS=30
MYSQLDUMP_BINARY=/usr/bin/mariadb-dump
QUICKBOOKS_ENVIRONMENT=production

# Unified communications provider routing
COMMUNICATION_FALLBACK_ENABLED=true

# AWS credentials may be omitted when the host uses an IAM role.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# AWS End User Messaging SMS
AWS_EUM_ORIGINATION_IDENTITY=
AWS_EUM_CONFIGURATION_SET=
AWS_EUM_MESSAGE_TYPE=TRANSACTIONAL

# Amazon SNS SMS and topic publishing
AWS_SNS_SMS_SENDER_ID=RockBluffs
AWS_SNS_SMS_TYPE=Transactional
AWS_SNS_TOPIC_ARN=

# Amazon SES (optional; provider is disabled by default)
AWS_SES_FROM_EMAIL=
AWS_SES_REPLY_TO=

# Azure Communication Services
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_COMMUNICATION_ENDPOINT=
AZURE_COMMUNICATION_ACCESS_KEY=
AZURE_COMMUNICATION_SMS_FROM=
AZURE_COMMUNICATION_SMS_API_VERSION=2021-03-07
AZURE_COMMUNICATION_EMAIL_FROM=
AZURE_COMMUNICATION_EMAIL_API_VERSION=2023-03-31

# ServiceOS 0.31 unified communication callbacks
DEFAULT_COUNTRY_CODE=1
COMMUNICATION_WEBHOOK_SECRET=
# Configure provider callbacks as:
# https://your-host/webhooks/communications/aws?secret=...
# https://your-host/webhooks/communications/azure?secret=...
# https://your-host/webhooks/communications/twilio?secret=...

# ServiceOS 0.32.1 geospatial foundation
GOOGLE_MAPS_API_KEY=
GEOCODING_DEFAULT_PROVIDER=nominatim
GEOCODING_CACHE_DAYS=180
GEOCODING_USER_AGENT=ServiceOS/0.32.1
GEOCODING_CONTACT_EMAIL=
GPS_LOCATION_RETENTION_DAYS=30

# CastorWorks AI Assistant
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
OLLAMA_ENDPOINT=http://127.0.0.1:11434
